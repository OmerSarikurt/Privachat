rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isUser(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- User Validation ---
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'displayName', 'photoURL', 'status', 'updatedAt']) 
             && data.keys().size() == 6
             && data.uid == request.auth.uid
             && data.email is string && data.email.size() <= 256
             && data.displayName is string && data.displayName.size() <= 100
             && data.photoURL is string && data.photoURL.size() <= 1024
             && data.status in ['online', 'offline']
             && data.updatedAt == request.time;
    }

    // --- Chat Validation ---
    function isValidChat(data) {
      return data.keys().hasAll(['members', 'createdAt', 'updatedAt'])
             && data.keys().size() <= 5 // Allow for lastMessage object
             && data.members is list
             && data.members.size() >= 1 && data.members.size() <= 10
             && request.auth.uid in data.members
             && data.createdAt == request.time
             && data.updatedAt == request.time;
    }

    // --- Message Validation ---
    function isValidMessage(data) {
      return data.keys().hasAll(['senderId', 'text', 'timestamp', 'chatId'])
             && data.keys().size() == 4
             && data.senderId == request.auth.uid
             && data.text is string && data.text.size() <= 5000
             && data.chatId is string
             && data.timestamp == request.time;
    }

    // --- Collection Routes ---

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && resource.data.uid == request.auth.uid; // Limit search unless specialized
      allow create: if isSignedIn() && isEmailVerified() && isValidUser(incoming());
      allow update: if isSignedIn() && isEmailVerified() && isUser(userId) && isValidUser(incoming())
                       && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt', 'displayName', 'photoURL']);
    }

    match /chats/{chatId} {
      allow get: if isSignedIn() && request.auth.uid in existing().members;
      allow list: if isSignedIn() && request.auth.uid in resource.data.members;
      allow create: if isSignedIn() && isEmailVerified() && isValidChat(incoming());
      allow update: if isSignedIn() && isEmailVerified() && request.auth.uid in existing().members && isValidChat(incoming())
                       && incoming().diff(existing()).affectedKeys().hasOnly(['lastMessage', 'updatedAt']);
      
      match /messages/{messageId} {
        allow list: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.members;
        allow create: if isSignedIn() && isEmailVerified() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.members 
                        && isValidMessage(incoming());
        allow delete: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.members;
      }
    }

    match /friendCodes/{codeId} {
      allow get: if isSignedIn();
      allow create: if isSignedIn() && isEmailVerified() && incoming().creatorId == request.auth.uid;
      allow delete: if isSignedIn() && (existing().creatorId == request.auth.uid || request.auth.uid != null);
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow create, update: if isSignedIn() && request.auth.uid == userId;
    }
  }
}
