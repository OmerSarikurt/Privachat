{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a user in the system",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string" },
        "status": { "type": "string", "enum": ["online", "offline"] },
        "lastSeen": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Chat": {
      "title": "Chat",
      "description": "A conversation between multiple users",
      "type": "object",
      "properties": {
        "members": { "type": "array", "items": { "type": "string" } },
        "lastMessage": { "type": "object" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["members", "createdAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A message within a chat",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "chatId": { "type": "string" }
      },
      "required": ["senderId", "text", "timestamp"]
    },
    "FriendCode": {
      "title": "Friend Code",
      "description": "A temporary code to initiate a chat",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "creatorId": { "type": "string" },
        "expiresAt": { "type": "string", "format": "date-time" }
      },
      "required": ["code", "creatorId", "expiresAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "chats/{chatId}": {
      "schema": "Chat",
      "description": "Chat metadata and active status"
    },
    "chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Individual messages within a chat"
    },
    "friendCodes/{codeId}": {
      "schema": "FriendCode",
      "description": "Temporary invitation codes"
    }
  }
}
